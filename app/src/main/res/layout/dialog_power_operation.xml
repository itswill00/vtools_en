<?xml version="1.0" encoding="utf-8"?>
<com.omarea.common.ui.OverScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:alpha="0.95"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:orientation="vertical">

        <TextView
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="16dp"
            style="@style/textTitle"
            android:text="System Power"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Primary Actions Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/power_shutdown"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/krscript_item_ripple"
                android:padding="12dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/power_shutdown"
                    android:background="@drawable/action_menu_icon_bg"
                    android:backgroundTint="#f9592f"
                    android:padding="8dp"
                    app:tint="#ffffff" />

                <TextView
                    style="@style/textTitle"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shutdown"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/power_reboot"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/krscript_item_ripple"
                android:padding="12dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/power_reboot"
                    android:background="@drawable/action_menu_icon_bg"
                    android:backgroundTint="#87cb00"
                    android:padding="8dp"
                    app:tint="#ffffff" />

                <TextView
                    style="@style/textTitle"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reboot"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Primary Actions Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/power_recovery"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/krscript_item_ripple"
                android:padding="12dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/power_recovery"
                    android:background="@drawable/action_menu_icon_bg"
                    android:backgroundTint="#fc8a1b"
                    android:padding="8dp"
                    app:tint="#ffffff" />

                <TextView
                    style="@style/textTitle"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recovery"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/power_fastboot"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:background="@drawable/krscript_item_ripple"
                android:padding="12dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/power_fastboot"
                    android:background="@drawable/action_menu_icon_bg"
                    android:backgroundTint="#138ed6"
                    android:padding="10dp"
                    app:tint="#ffffff" />

                <TextView
                    style="@style/textTitle"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fastboot"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_marginBottom="8dp"
            style="@style/textSmall"
            android:text="Advanced Options"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Hot Reboot -->
        <LinearLayout
            android:id="@+id/power_hot_reboot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/krscript_item_ripple"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/power_hot_reboot"
                android:background="@drawable/action_menu_icon_bg"
                android:backgroundTint="#00b9c2"
                android:padding="6dp"
                app:tint="#ffffff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="12dp"
                android:orientation="vertical">
                <TextView
                    style="@style/textTitle"
                    android:text="Hot Reboot"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    style="@style/textSmall"
                    android:text="Restarts SystemUI / Framework only"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- EDL Mode -->
        <LinearLayout
            android:id="@+id/power_emergency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/krscript_item_ripple"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/power_emergency"
                android:background="@drawable/action_menu_icon_bg"
                android:backgroundTint="#7800c2"
                android:padding="8dp"
                app:tint="#ffffff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="12dp"
                android:orientation="vertical">
                <TextView
                    style="@style/textTitle"
                    android:text="Emergency (9008)"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    style="@style/textSmall"
                    android:text="Reboot to EDL mode (Snapdragon devices)"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</com.omarea.common.ui.OverScrollView>
