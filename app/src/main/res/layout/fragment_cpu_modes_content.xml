<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.omarea.common.ui.OverScrollView
        android:id="@+id/cpu_modes_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/cpu_modes_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Mode Selection Card -->
            <LinearLayout
                android:id="@+id/cpu_modes_card_modes"
                style="@style/ListCardItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:layout_marginBottom="0dp"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/textTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Performance Profile"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/config_author"
                        style="@style/textSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="?android:colorAccent"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/config_author_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?android:selectableItemBackgroundBorderless"
                        android:padding="6dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/source_switch"
                        app:tint="?android:colorAccent" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/cpu_config_p0"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginRight="4dp"
                            android:background="@drawable/krscript_item_ripple"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/mode_powersave"
                                android:background="@drawable/action_menu_icon_bg"
                                android:backgroundTint="#8bc34a"
                                android:padding="6dp"
                                app:tint="#ffffff" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:orientation="vertical">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/powersave"
                                    android:textSize="14sp" />
                                <TextView
                                    style="@style/textSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Power"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cpu_config_p1"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginLeft="4dp"
                            android:background="@drawable/krscript_item_ripple"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/mode_balance"
                                android:background="@drawable/action_menu_icon_bg"
                                android:backgroundTint="#00bcd4"
                                android:padding="7dp"
                                app:tint="#ffffff" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:orientation="vertical">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/balance"
                                    android:textSize="14sp" />
                                <TextView
                                    style="@style/textSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Normal"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/cpu_config_p2"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginRight="4dp"
                            android:background="@drawable/krscript_item_ripple"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/mode_performance"
                                android:background="@drawable/action_menu_icon_bg"
                                android:backgroundTint="#ff9800"
                                android:padding="6dp"
                                app:tint="#ffffff" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:orientation="vertical">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/performance"
                                    android:textSize="14sp" />
                                <TextView
                                    style="@style/textSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gaming"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cpu_config_p3"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginLeft="4dp"
                            android:background="@drawable/krscript_item_ripple"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/mode_fast"
                                android:background="@drawable/action_menu_icon_bg"
                                android:backgroundTint="#f44336"
                                android:padding="8dp"
                                app:tint="#ffffff" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:orientation="vertical">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/fast"
                                    android:textSize="14sp" />
                                <TextView
                                    style="@style/textSmall"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Extreme"
                                    android:alpha="0.6" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Service Notice -->
            <LinearLayout
                android:id="@+id/cpu_modes_card_service_notice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/nav_scene_service_not_active"
                    style="@style/ListCardItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:layout_marginTop="0dp"
                    android:layout_marginBottom="12dp"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/nav_icon_warn"
                            app:tint="?android:colorAccent" />
                        <TextView
                            style="@style/textDefault"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:text="@string/accessibility_activate"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        style="@style/textSmall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/accessibility_activate_desc" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dynamic Control Card -->
            <LinearLayout
                android:id="@+id/cpu_modes_card_dynamic"
                style="@style/ListCardItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:padding="16dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/action_menu_icon_bg"
                        android:backgroundTint="?android:colorAccent"
                        android:padding="8dp"
                        android:src="@drawable/auto"
                        app:tint="#ffffff" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="16dp"
                        android:orientation="vertical">
                        <Switch
                            android:id="@+id/dynamic_control"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_scene"
                            android:textStyle="bold" />
                        <TextView
                            style="@style/textSmall"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_scene_desc" />
                    </LinearLayout>
                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/dynamic_control_opts"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <com.omarea.ui.UMExpandLayout
                        android:id="@+id/dynamic_control_opts2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/in_card_item_inactive"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <!-- Screen On Mode -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/schedule_screen_on" />
                                <Spinner
                                    android:id="@+id/first_mode"
                                    style="@style/SceneSpinner"
                                    android:layout_width="120dp"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10000000"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp" />

                            <!-- Screen Off Mode -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">
                                <TextView
                                    style="@style/textTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/schedule_screen_off" />
                                <Spinner
                                    android:id="@+id/sleep_mode"
                                    style="@style/SceneSpinner"
                                    android:layout_width="120dp"
                                    android:layout_height="wrap_content" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10000000"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp" />

                            <Switch
                                android:id="@+id/strict_mode"
                                style="@style/textTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/schedule_enhanced" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10000000"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp" />

                            <Switch
                                android:id="@+id/delay_switch"
                                style="@style/textTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/schedule_delay" />
                        </LinearLayout>
                    </com.omarea.ui.UMExpandLayout>

                    <ImageView
                        android:layout_below="@id/dynamic_control_opts2"
                        android:id="@+id/dynamic_control_toggle"
                        android:src="@drawable/arrow_down"
                        android:padding="4dp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="60dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/krscript_item_ripple"
                        android:layout_height="24dp"
                        app:tint="?android:colorAccent" />
                </RelativeLayout>

                <!-- Extreme Performance Section -->
                <LinearLayout
                    android:id="@+id/extreme_performance"
                    android:layout_marginTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/action_menu_icon_bg"
                        android:backgroundTint="#FF5252"
                        android:padding="7dp"
                        android:src="@drawable/icon_danger"
                        app:tint="#ffffff" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginLeft="16dp"
                        android:orientation="vertical">
                        <Switch
                            android:id="@+id/extreme_performance_on"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_excellent"
                            android:textStyle="bold" />
                        <TextView
                            style="@style/textSmall"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/schedule_excellent_desc" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Shortcuts Card -->
            <LinearLayout
                android:id="@+id/cpu_modes_card_shortcuts"
                style="@style/ListCardItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:layout_marginTop="12dp"
                android:padding="16dp"
                android:orientation="vertical">

                <TextView
                    style="@style/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shortcuts"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Battery Stats -->
                <LinearLayout
                    android:id="@+id/nav_battery_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/krscript_item_ripple"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_bat_stats"
                        android:background="@drawable/action_menu_icon_bg"
                        android:backgroundTint="?android:colorAccent"
                        android:padding="6dp"
                        app:tint="#ffffff" />
                    <TextView
                        style="@style/textTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/menu_battery_stats" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/arrow"
                        app:tint="#40000000" />
                </LinearLayout>

                <!-- App Scene -->
                <LinearLayout
                    android:id="@+id/nav_app_scene"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/krscript_item_ripple"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_menu_profile"
                        android:background="@drawable/action_menu_icon_bg"
                        android:backgroundTint="?android:colorAccent"
                        android:padding="6dp"
                        app:tint="#ffffff" />
                    <TextView
                        style="@style/textTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="@string/schedule_app" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/arrow"
                        app:tint="#40000000" />
                </LinearLayout>

                <!-- Auto Click -->
                <LinearLayout
                    android:id="@+id/nav_skip_ad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/krscript_item_ripple"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_menu_click"
                        android:background="@drawable/action_menu_icon_bg"
                        android:backgroundTint="?android:colorAccent"
                        android:padding="6dp"
                        app:tint="#ffffff" />
                    <TextView
                        style="@style/textTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="12dp"
                        android:text="Auto clicker" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/arrow"
                        app:tint="#40000000" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/nav_more"
                android:visibility="gone"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null">

                <TextView
                    android:text="More Advanced Features"
                    style="@style/textSmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold" />
                
                <LinearLayout
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/nav_thermal"
                        android:text="Thermal"
                        style="@style/textTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="16dp"
                        android:textColor="?android:colorAccent" />
                    <TextView
                        android:id="@+id/nav_processes"
                        android:text="Processes"
                        style="@style/textTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="16dp"
                        android:textColor="?android:colorAccent" />
                    <TextView
                        android:id="@+id/nav_freeze"
                        android:text="Freeze"
                        style="@style/textTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?android:colorAccent" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.omarea.common.ui.OverScrollView>
</RelativeLayout>
